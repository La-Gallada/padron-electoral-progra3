    private void jButton3ActionPerformed(java.awt.event.ActionEvent evt) {                                         
 new Thread(() -> {

    txtArea.setText("Buscando...\n");

    RepositorioPadronTxt repo = new RepositorioPadronTxt();
    RepositorioDistelecTxt repoDir = new RepositorioDistelecTxt();

    repoDir.cargar();

    String cedula = TX1.getText();

    String resultado = repo.buscarPorCedula(cedula);

    if (resultado != null) {

        String[] datos = resultado.split(",");

        String nombre = datos[0];
        String codElec = datos[1];

        Direccion dir = repoDir.obtenerDireccion(codElec);

        txtArea.append("Nombre: " + nombre + "\n");
        txtArea.append("Cedula: " + cedula + "\n");
        txtArea.append("Direccion: " + dir + "\n");

    } else {

        txtArea.append("Resultado no encontrado\n");

    }

}).start();

        // TODO add your handling code here:
    }                                        

